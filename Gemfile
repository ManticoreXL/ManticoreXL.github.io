source "https://rubygems.org"

# GitHub Pages가 빌드에 사용하는 gem 세트 (Jekyll 버전을 GitHub Pages와 일치시킴)
gem "github-pages", group: :jekyll_plugins

# Minimal Mistakes를 remote theme로 불러오기 위한 의존성
gem "jekyll-remote-theme"

# Minimal Mistakes 필수 플러그인 (없으면 include_cached 빌드 에러 발생)
gem "jekyll-include-cache", group: :jekyll_plugins

# 로컬 미리보기(bundle exec jekyll serve)용 — Ruby 3.0+ 에서 필요
gem "webrick", "~> 1.8"
